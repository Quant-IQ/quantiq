{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Main Orchestrator",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/engine.py",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Run Active File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}